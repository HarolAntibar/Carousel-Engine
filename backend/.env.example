# --- APIs externas (requeridas) ----------------------------------------------

# Anthropic — obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# fal.ai — obtener en: https://fal.ai/dashboard/keys
FAL_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Modelo Claude (opcional) ------------------------------------------------

CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS=2048
