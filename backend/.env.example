# =============================================================================
# CONTENT AUTOMATION — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el .env a GitHub.
# =============================================================================

# --- APIs externas (requeridas) ----------------------------------------------

# Anthropic — obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# fal.ai — obtener en: https://fal.ai/dashboard/keys
FAL_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Modelo Claude (opcional) ------------------------------------------------

CLAUDE_MODEL=claude-opus-4-8
CLAUDE_MAX_TOKENS=8192

# --- Pipeline (opcional) -------------------------------------------------------

# Score mínimo para generar imágenes. Contenido con score menor se rechaza
# ANTES de llamar a fal.ai (RejectedResponse).
AUTHORITY_THRESHOLD=0.7

# Carpeta raíz donde se guardan los carruseles generados.
CAROUSELS_OUTPUT_DIR=./carousels

# Marca de agua dibujada en la esquina inferior derecha de cada slide.
WATERMARK_HANDLE=@Harol_antibar
